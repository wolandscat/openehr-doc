| 
| Address of contact, which may be electronic or geographic.
| 

class ADDRESS
    is_a LOCATABLE

feature_group ("access")

    | 
    | Archetypable structured address.
    | 
    prop details: ITEM_STRUCTURE;

    | 
    | Type of address, e.g. electronic, locality. Taken from value of inherited `name`
    | attribute.
    | 
    func type:DV_TEXT
        ;

invariant
    type_valid: type = name;

end

| 
| This class is used to create intermediate representations of data from sources not
| otherwise conforming to openEHR classes, such as HL7 messages, relational databases and so
| on.
| 

class GENERIC_ENTRY
    is_a CONTENT_ITEM

feature_group ("access")

    | 
    | The data from the source message or record. May be recorded in any structural openEHR
    | representation.
    | 
    prop data: ITEM;


end

| 
| Defines an array of optionally named items each of any type.
| 

class EL_TUPLE
    is_a EL_EXPRESSION

feature_group ("access")

    | 
    | Items in the tuple, potentially with names. Typical use is to represent an argument list
    | to routine call.
    | 
    prop items: List<EL_TUPLE_ITEM>;

    | 
    | Static type inferred from literal value.
    | 
    prop type: BMM_TUPLE_TYPE;

    | 
    | Return `type`.
    | 
    func eval_type:BMM_TYPE
        ;


end

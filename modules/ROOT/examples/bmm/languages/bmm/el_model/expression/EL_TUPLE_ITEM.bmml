| 
| A single tuple item, with an optional name.
| 

class EL_TUPLE_ITEM
    is_a Any

feature_group ("access")

    | 
    | Reference to value entity. If Void, this indicates that the item in this position is Void,
    | e.g. within a routine call parameter list.
    | 
    prop item: EL_EXPRESSION;

    | 
    | Optional name of tuple item.
    | 
    prop name: String;


end

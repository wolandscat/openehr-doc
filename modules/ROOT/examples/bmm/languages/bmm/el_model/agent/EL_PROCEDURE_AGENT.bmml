| 
| An agent whose signature is of a procedure, i.e. has no result type.
| 

class EL_PROCEDURE_AGENT
    is_a EL_AGENT

feature_group ("access")

    | 
    | Reference to definition of routine for which this is a call instance.
    | 
    prop definition: BMM_PROCEDURE;

    | 
    | Eval type is the signature corresponding to the (remaining) open arguments and return
    | type, if any.
    | 
    func eval_type:BMM_PROCEDURE_TYPE
        post_cond
            result_validity: Result = definition.signature;
        ;


end

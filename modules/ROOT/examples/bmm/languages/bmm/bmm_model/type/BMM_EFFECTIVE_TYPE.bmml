| 
| Meta-type for a concrete, unitary type that can be used as an actual parameter type in a
| generic type declaration.
| 

abstract class BMM_EFFECTIVE_TYPE
    is_a BMM_UNITARY_TYPE

feature_group ("access")

    | 
    | Result = self.
    | 
    func effective_type:BMM_EFFECTIVE_TYPE
        ;

    | 
    | Name of base generator type, i.e. excluding any generic parts if present.
    | 
    func type_base_name:String
        ;


end
